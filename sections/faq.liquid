{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
</style>
{% endif %}
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
  </div>
  <div style="max-width:720px;margin:0 auto;">
    {% for block in section.blocks %}
      {% if block.type == 'question' %}
        <details style="margin-bottom:16px;border:1px solid var(--gray-800);border-radius:12px;overflow:hidden;" {{ block.shopify_attributes }}>
          <summary style="padding:18px 24px;font-size:15px;font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            {{ block.settings.question }}
            <span style="font-size:20px;color:var(--orange);transition:transform 0.2s;">+</span>
          </summary>
          <div style="padding:0 24px 18px;font-size:14px;color:var(--gray-400);line-height:1.7;">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "header", "content": "Section Colors" },
    { "type": "text", "id": "bg_color", "label": "Background Color" },
    { "type": "text", "id": "text_color", "label": "Text Color" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What do I bring?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Indoor boots or trainers, shin pads, water bottle, and sunscreen." }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
