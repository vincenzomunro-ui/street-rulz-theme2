{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Image Break / Parallax Section {% endcomment %}
{% if section.settings.background_image != blank %}
<div class="parallax-break" style="background-image:url('{{ section.settings.background_image | image_url: width: 1920 }}');">
{% else %}
<div class="parallax-break" style="background-image:url('{{ 'pitches-aerial-day-1.jpg' | asset_url }}');">
{% endif %}
  <div class="parallax-overlay">
    {% if section.settings.show_logo %}
      <img src="{{ 'logo.png' | asset_url }}" alt="Street Rulz Football" class="parallax-logo">
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link }}" class="btn-primary" style="margin-top:20px;">{{ section.settings.cta_text }}</a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image Break",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Wide landscape photo (1920x600px recommended)"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show Logo",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ],
  "presets": [
    {
      "name": "Image Break"
    }
  ]
}
{% endschema %}