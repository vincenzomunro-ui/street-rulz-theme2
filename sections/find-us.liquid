{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Find Us — Map + Contact Info {% endcomment %}
<div class="section-dark">
  <div class="section">
    <div class="section-label">{{ section.settings.label }}</div>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <p class="section-subtitle" style="margin-bottom:32px;">{{ section.settings.subheading }}</p>

    <div class="grid-2" style="gap:32px;">
      <div class="card" style="padding:0;overflow:hidden;min-height:350px;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3516.8!2d153.4202868!3d-28.1344192!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b9103d39e8ab9c7%3A0x5e9ea34ba73b35f2!2sStreet%20Rulz%20Football!5e0!3m2!1sen!2sau!4v1708300000000!5m2!1sen!2sau"
          width="100%" height="100%" style="border:0;min-height:350px;" allowfullscreen loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Street Rulz Football Location">
        </iframe>
      </div>
      <div>
        <div class="card" style="margin-bottom:16px;">
          <h3 style="font-size:18px;font-weight:700;margin-bottom:16px;">📍 {{ section.settings.address_title }}</h3>
          <p style="font-size:15px;color:var(--gray-200);line-height:1.8;">{{ section.settings.address }}</p>
          <a href="https://www.google.com/maps/dir//Street+Rulz+Football,+40+Andrews+Rd,+Tallebudgera+QLD+4228,+Australia" target="_blank" class="btn-primary" style="margin-top:16px;">Get Directions</a>
        </div>
        <div class="card">
          <h3 style="font-size:18px;font-weight:700;margin-bottom:16px;">📞 Contact</h3>
          <p style="font-size:15px;color:var(--gray-200);line-height:2;">
            <a href="tel:+61412766969" style="color:var(--orange);">Mark</a><br>
            <a href="mailto:admin@rulz.com.au" style="color:var(--orange);">admin@rulz.com.au</a><br>
            <a href="https://www.facebook.com/StreetRulzFootball/" target="_blank" style="color:var(--orange);">Facebook</a> · 
            <a href="https://www.instagram.com/streetrulz_football/" target="_blank" style="color:var(--orange);">Instagram</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Find Us",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "FIND US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Come Play"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Located at Tallebudgera on the Gold Coast. Easy access from the M1 motorway."
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "Address Title",
      "default": "Street Rulz Football"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Full Address",
      "default": "40 Andrews Road\nTallebudgera QLD 4228\nGold Coast, Queensland\nAustralia"
    },
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ],
  "presets": [
    {
      "name": "Find Us"
    }
  ]
}
{% endschema %}