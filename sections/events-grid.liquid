{% comment %} Events Grid — Block-based event cards, expandable via theme editor {% endcomment %}

{%- assign bg = section.settings.bg_color | default: '#0f1110' -%}
{%- assign text_col = section.settings.text_color | default: '' -%}
{%- assign card_col = section.settings.card_color | default: '#1d1f1e' -%}

<div class="section" style="{% if bg != blank %}background:{{ bg }};{% endif %}{% if text_col != blank %}color:{{ text_col }};{% endif %}">
  {% if section.settings.heading != blank %}
    <h2 class="section-title" style="text-align:center;">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p style="text-align:center;max-width:640px;margin:0 auto 40px;font-size:16px;color:var(--gray-300);line-height:1.6;">
      {{ section.settings.subheading }}
    </p>
  {% endif %}

  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));gap:24px;max-width:1100px;margin:0 auto;">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" style="text-decoration:none;color:inherit;" {{ block.shopify_attributes }}>
        <div style="background:{{ card_col }};border-radius:16px;overflow:hidden;border:1px solid var(--gray-700, #333);transition:transform 0.2s, box-shadow 0.2s;cursor:pointer;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)'" onmouseout="this.style.transform='none';this.style.boxShadow='none'">

          {%- comment -%} Event Image {%- endcomment -%}
          {% if block.settings.image != blank %}
            <div style="width:100%;height:200px;overflow:hidden;">
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;"
              >
            </div>
          {% else %}
            <div style="width:100%;height:200px;background:linear-gradient(135deg, var(--orange, #ff6600) 0%, #cc5200 100%);display:flex;align-items:center;justify-content:center;">
              <span style="font-size:48px;">⚽</span>
            </div>
          {% endif %}

          <div style="padding:20px 24px 24px;">
            {%- comment -%} Badge {%- endcomment -%}
            {% if block.settings.badge != blank %}
              <span style="display:inline-block;background:var(--orange, #ff6600);color:#fff;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1px;padding:4px 10px;border-radius:4px;margin-bottom:12px;">
                {{ block.settings.badge }}
              </span>
            {% endif %}

            {%- comment -%} Title {%- endcomment -%}
            <h3 style="font-size:20px;font-weight:800;color:var(--white, #fff);margin:0 0 8px;line-height:1.3;">
              {{ block.settings.title }}
            </h3>

            {%- comment -%} Date {%- endcomment -%}
            {% if block.settings.date != blank %}
              <p style="font-size:14px;color:var(--orange, #ff6600);font-weight:600;margin:0 0 12px;text-transform:uppercase;letter-spacing:0.5px;">
                {{ block.settings.date }}
              </p>
            {% endif %}

            {%- comment -%} Description {%- endcomment -%}
            {% if block.settings.description != blank %}
              <p style="font-size:14px;color:var(--gray-300, #ccc);line-height:1.6;margin:0 0 16px;">
                {{ block.settings.description }}
              </p>
            {% endif %}

            {%- comment -%} Price {%- endcomment -%}
            {% if block.settings.price != blank %}
              <p style="font-size:16px;font-weight:700;color:var(--green, #22c55e);margin:0 0 16px;">
                {{ block.settings.price }}
              </p>
            {% endif %}

            {%- comment -%} CTA {%- endcomment -%}
            <span style="display:inline-block;background:var(--orange, #ff6600);color:#fff;font-weight:700;font-size:14px;padding:10px 24px;border-radius:8px;text-transform:uppercase;letter-spacing:0.5px;">
              {{ block.settings.cta_text | default: 'Learn More' }}
            </span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Events Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Upcoming Events" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Check out what's coming up at Street Rulz Football. Click an event to find out more and register." },
    { "type": "color", "id": "bg_color", "label": "Background color" },
    { "type": "color", "id": "text_color", "label": "Text color" },
    { "type": "color", "id": "card_color", "label": "Card color" }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Event image" },
        { "type": "text", "id": "title", "label": "Event title", "default": "Event Name" },
        { "type": "text", "id": "date", "label": "Date", "default": "Saturday 7 June 2026" },
        { "type": "textarea", "id": "description", "label": "Short description", "default": "A brief description of the event." },
        { "type": "text", "id": "price", "label": "Price (e.g. From $30/head)", "default": "" },
        { "type": "text", "id": "badge", "label": "Badge (e.g. NEW, SELLING FAST)", "default": "" },
        { "type": "text", "id": "cta_text", "label": "Button text", "default": "Learn More" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events Grid",
      "blocks": [
        { "type": "event" }
      ]
    }
  ]
}
{% endschema %}
