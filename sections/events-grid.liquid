<style>
  .events-grid-section {
    padding: 60px 20px;
  }
  .events-grid-title {
    text-align: center;
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 12px;
  }
  .events-grid-subtitle {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
    font-size: 16px;
    opacity: 0.7;
    line-height: 1.6;
  }
  .events-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .events-grid-card {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #333;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .events-grid-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .events-grid-card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  .events-grid-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .events-grid-card-placeholder {
    width: 100%;
    height: 200px;
    background: linear-gradient(135deg, #ff6600 0%, #cc5200 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
  }
  .events-grid-card-body {
    padding: 20px 24px 24px;
  }
  .events-grid-badge {
    display: inline-block;
    background: #ff6600;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 12px;
  }
  .events-grid-card-title {
    font-size: 20px;
    font-weight: 800;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .events-grid-card-date {
    font-size: 14px;
    color: #ff6600;
    font-weight: 600;
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .events-grid-card-desc {
    font-size: 14px;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .events-grid-card-price {
    font-size: 16px;
    font-weight: 700;
    color: #22c55e;
    margin: 0 0 16px;
  }
  .events-grid-cta {
    display: inline-block;
    background: #ff6600;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    padding: 10px 24px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>

<div class="events-grid-section" style="{% if section.settings.bg_color != blank %}background:{{ section.settings.bg_color }};{% endif %}{% if section.settings.text_color != blank %}color:{{ section.settings.text_color }};{% endif %}">
  {% if section.settings.heading != blank %}
    <h2 class="events-grid-title">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="events-grid-subtitle">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="events-grid-container">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="events-grid-card" style="{% if section.settings.card_color != blank %}background:{{ section.settings.card_color }};{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="events-grid-card-image">
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
            >
          </div>
        {% else %}
          <div class="events-grid-card-placeholder">&#9917;</div>
        {% endif %}

        <div class="events-grid-card-body">
          {% if block.settings.badge != blank %}
            <span class="events-grid-badge">{{ block.settings.badge }}</span>
          {% endif %}

          <h3 class="events-grid-card-title">{{ block.settings.title }}</h3>

          {% if block.settings.date != blank %}
            <p class="events-grid-card-date">{{ block.settings.date }}</p>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="events-grid-card-desc">{{ block.settings.description }}</p>
          {% endif %}

          {% if block.settings.price != blank %}
            <p class="events-grid-card-price">{{ block.settings.price }}</p>
          {% endif %}

          <span class="events-grid-cta">{{ block.settings.cta_text | default: 'Learn More' }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Events Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Upcoming Events" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Check out what's coming up at Street Rulz Football." },
    { "type": "color", "id": "bg_color", "label": "Background color" },
    { "type": "color", "id": "text_color", "label": "Text color" },
    { "type": "color", "id": "card_color", "label": "Card color" }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Event image" },
        { "type": "text", "id": "title", "label": "Event title", "default": "Event Name" },
        { "type": "text", "id": "date", "label": "Date", "default": "Saturday 7 June 2026" },
        { "type": "textarea", "id": "description", "label": "Short description", "default": "A brief description of the event." },
        { "type": "text", "id": "price", "label": "Price", "default": "" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "" },
        { "type": "text", "id": "cta_text", "label": "Button text", "default": "Learn More" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events Grid"
    }
  ]
}
{% endschema %}
