          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "Patricia Munro",
            "role": "Co-Founder",
            "bio": "A foundational force behind Rulz, Patricia has been instrumental in shaping the vision and bringing the facility to life. Her dedication, organisation, and operational guidance ensure the business runs seamlessly day to day."
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "Vincenzo Munro",
            "role": "Manager",
            "bio": "Vincenzo plays a central role in the operational and creative direction of Rulz. With over 10 years of futsal, 5-a-side, and community football experience, he has played a key role in shaping the identity of Street Rulz Football."
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "Ruby Grant",
            "role": "Assistant Manager",
            "bio": "Ruby plays a key role in both operations and the creative direction of Rulz. As Assistant Manager, she oversees business systems, marketing, branding, and member experience."
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "Greg Jones",
            "role": "Groundskeeper",
