<!-- Time Slots & Duration Options -->
<div class="section-dark">
  <div class="section">
    <div style="text-align:center;margin-bottom:40px;">
      <p class="section-label">{{ section.settings.label }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-subtitle" style="margin:0 auto;">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="time-slots-grid">
      {% for block in section.blocks %}
        <div class="time-slot-card {% if block.settings.highlighted %}card-highlight{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}
            <div class="card-badge">{{ block.settings.badge }}</div>
          {% endif %}
          <div class="time-slot-duration">{{ block.settings.duration }}</div>
          <h3 class="time-slot-title">{{ block.settings.title }}</h3>
          <p class="time-slot-desc">{{ block.settings.description }}</p>
          {% if block.settings.price != blank %}
            <div class="time-slot-price">{{ block.settings.price }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}
      <p style="text-align:center;margin-top:28px;font-size:13px;color:var(--gray-400);">{{ section.settings.note }}</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Time Slots",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "FLEXIBLE BOOKING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose Your Session Length" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Book the time that suits your game. All sessions include balls and bibs." },
    { "type": "text", "id": "note", "label": "Bottom note", "default": "Prices shown are for 5-a-side courts. 7-a-side pricing may vary." }
  ],
  "blocks": [
    {
      "type": "slot",
      "name": "Time Slot",
      "settings": [
        { "type": "text", "id": "duration", "label": "Duration display", "default": "30 min" },
        { "type": "text", "id": "title", "label": "Title", "default": "Quick Kick" },
        { "type": "text", "id": "badge", "label": "Badge text" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight this card", "default": false },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "price", "label": "Price text" }
      ]
    }
  ]
}
{% endschema %}
