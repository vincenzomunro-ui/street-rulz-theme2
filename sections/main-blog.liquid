{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Main Blog — Lists blog articles {% endcomment %}
<div class="section">
  <h1 class="section-title">{{ blog.title }}</h1>
  <div class="grid-3">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" class="card" style="text-decoration:none;">
        {% if article.image %}
          <img src="{{ article.image | image_url: width: 400 }}" alt="{{ article.title }}" style="border-radius:8px;margin-bottom:16px;">
        {% endif %}
        <h3 style="font-size:16px;font-weight:700;margin-bottom:8px;">{{ article.title }}</h3>
        <p style="color:var(--gray-400);font-size:13px;">{{ article.published_at | date: '%B %d, %Y' }}</p>
      </a>
    {% endfor %}
  </div>
  {% paginate blog.articles by 12 %}
    {% if paginate.pages > 1 %}
      <div style="text-align:center;margin-top:32px;">
        {{ paginate | default_pagination }}
      </div>
    {% endif %}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ]
}
{% endschema %}