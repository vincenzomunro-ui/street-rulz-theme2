{% comment %} Main Product — Product display with required email capture {% endcomment %}

{% comment %} CUSTOM TEMPLATE ROUTING — Check for template_suffix and load custom section {% endcomment %}
{% if product.template_suffix == 'product-fiesta' %}
  {% section 'product-fiesta' %}
{% elsif product.template_suffix == 'product-party' %}
  {% section 'product-party' %}
{% else %}
  {%- comment -%} DEFAULT PRODUCT FORM {%- endcomment -%}
  <div class="section">
    <h1 class="section-title">{{ product.title }}</h1>
    <div style="max-width:720px;font-size:16px;color:var(--gray-200);line-height:1.8;">
      {{ product.description }}
    </div>
    {% if product.available %}
      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <div style="margin-top:24px;max-width:480px;">
        {%- comment -%} Your Full Name — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="customer-name" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Your Full Name <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="text"
            id="customer-name"
            name="properties[Full Name]"
            placeholder="e.g. John Smith"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Email Address — Required {%- endcomment -%}
        <div style="margin-bottom:24px;">
          <label for="customer-email" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Email Address <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="email"
            id="customer-email"
            name="properties[Email]"
            placeholder="e.g. john@example.com"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            We'll send your confirmation and any updates to this email.
          </p>
        </div>
      </div>

        <button type="submit" class="btn-primary" style="margin-top:8px;">
          Add to Cart — {{ product.price | money }}
        </button>
      {% endform %}
    {% else %}
      <p style="margin-top:24px;font-size:18px;color:var(--orange);font-weight:700;">Currently Unavailable</p>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
