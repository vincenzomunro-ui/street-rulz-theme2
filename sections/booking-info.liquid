{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
<!-- Booking Info / What's Included Section -->
<div class="section-dark">
  <div class="section">
    <div style="text-align:center;margin-bottom:40px;">
      <p class="section-label">{{ section.settings.label }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="booking-info-grid">
      {% for block in section.blocks %}
        <div class="booking-info-item" {{ block.shopify_attributes }}>
          <div class="booking-info-icon">{{ block.settings.icon }}</div>
          <div>
            <h4 style="font-size:15px;font-weight:700;margin-bottom:4px;">{{ block.settings.title }}</h4>
            <p style="font-size:13px;color:var(--gray-400);line-height:1.6;">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Booking Info",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "INCLUDED WITH EVERY BOOKING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What You Get"
    },
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon/emoji",
          "default": "\u26bd"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ]
}
{% endschema %}