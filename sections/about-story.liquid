<section id="about-story" class="about-story">
  <div class="container">
    <div class="story-grid">
      <div class="story-content">
        <span class="section-badge">{{ section.settings.badge | default: 'OUR STORY' }}</span>
        <h2 class="story-heading">{{ section.settings.heading | default: 'Built from the Ground Up' }}</h2>
        <div class="story-text">
          {{ section.settings.text }}
        </div>
      </div>
      <div class="story-image">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image_alt | default: 'Street Rulz Football' }}"
            loading="lazy"
            width="800"
            height="600"
          >
        {% else %}
          <div class="story-image-placeholder">
            <span>📸</span>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Values Row -->
    {% if section.blocks.size > 0 %}
      <div class="values-grid">
        {% for block in section.blocks %}
          {% if block.type == 'value' %}
            <div class="value-card" {{ block.shopify_attributes }}>
              <span class="value-icon">{{ block.settings.icon }}</span>
              <h3 class="value-title">{{ block.settings.title }}</h3>
              <p class="value-text">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .about-story {
    padding: 80px 0;
    background: var(--color-bg, #0a0a0a);
  }

  .about-story .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 60px;
  }

  .about-story .section-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent, #ff6b00);
    background: rgba(255, 107, 0, 0.1);
    border: 1px solid rgba(255, 107, 0, 0.3);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .story-heading {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-text, #ffffff);
    margin: 16px 0 24px 0;
    line-height: 1.1;
  }

  .story-text {
    font-size: 1rem;
    color: var(--color-muted, #999999);
    line-height: 1.8;
  }

  .story-text p {
    margin-bottom: 16px;
  }

  .story-image {
    border-radius: 16px;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.06);
  }

  .story-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    min-height: 400px;
  }

  .story-image-placeholder {
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #141414, #1a1a1a);
    font-size: 4rem;
  }

  /* Values Grid */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .value-card {
    text-align: center;
    padding: 32px 20px;
  }

  .value-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 12px;
  }

  .value-title {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text, #ffffff);
    margin: 0 0 8px 0;
  }

  .value-text {
    font-size: 0.9rem;
    color: var(--color-muted, #999999);
    line-height: 1.6;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-story {
      padding: 60px 0;
    }

    .story-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .story-image {
      order: -1;
    }

    .values-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "About — Story",
  "tag": "section",
  "class": "about-story-section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built from the Ground Up"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Story Text",
      "default": "<p>Street Rulz Football was born from a simple belief — that the Gold Coast deserves a world-class small-sided football facility where community, culture, and competition come together.</p><p>What started as a family vision has grown into 7 premium enclosed courts at Tallebudgera, built with FIFA Grade 3 artificial turf and designed for players of every level. From casual kick-abouts to competitive leagues, birthday parties to junior academies — Rulz is where street culture meets elite football.</p><p>We're a family-run business, and that's by design. Every decision we make is driven by a genuine love for the game and a commitment to the community we serve.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Street Rulz Football facility"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "⚽"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Community"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Building connections through the beautiful game."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About — Story",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "⚽",
            "title": "Community",
            "text": "Building connections through the beautiful game."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "🏟️",
            "title": "Quality",
            "text": "FIFA Grade 3 turf and premium enclosed courts."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "👨‍👩‍👧‍👦",
            "title": "Family",
            "text": "Family-owned, family-run, family-focused."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "🔥",
            "title": "Passion",
            "text": "Decades of football experience in every detail."
          }
        }
      ]
    }
  ]
}
{% endschema %}
