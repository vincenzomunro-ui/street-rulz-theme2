{% if section.settings.bg_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }} !important;
  }
</style>
{% endif %}

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .gallery-grid .gallery-item:first-child {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .gallery-item {
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    aspect-ratio: 16/10;
    background: var(--gray-800);
  }
  .gallery-item:first-child {
    aspect-ratio: auto;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.03);
  }
  .gallery-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--gray-400);
    font-size: 13px;
    gap: 8px;
  }
  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    font-size: 12px;
    color: var(--gray-200);
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    .gallery-grid .gallery-item:first-child {
      grid-column: auto;
      grid-row: auto;
    }
    .gallery-item {
      aspect-ratio: 16/9;
    }
  }
</style>

<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="gallery-grid">
    {% for block in section.blocks %}
      {% if block.type == 'photo' %}
        <div class="gallery-item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.caption | default: 'Street Rulz Football' }}" loading="lazy">
            {% if block.settings.caption != blank %}
              <div class="gallery-caption">{{ block.settings.caption }}</div>
            {% endif %}
          {% else %}
            <div class="gallery-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="opacity:0.3;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              Upload photo
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Photo Gallery",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "GALLERY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See Our Facility"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Photo Gallery"
    }
  ]
}
{% endschema %}
