{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
</style>
{% endif %}

<style>
  .rules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }
  .rule-card {
    background: var(--dark-card);
    border: 1px solid var(--gray-600);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    text-align: center;
    transition: border-color var(--transition), transform var(--transition);
  }
  .rule-card:hover {
    border-color: var(--orange-border);
    transform: translateY(-2px);
  }
  .rule-icon {
    width: 48px;
    height: 48px;
    background: var(--orange-bg);
    border: 1px solid var(--orange-border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    font-size: 22px;
  }
  .rule-card h3 {
    font-family: 'Archivo Black', sans-serif;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    color: var(--white);
  }
  .rule-card p {
    font-size: 13px;
    color: var(--gray-400);
    line-height: 1.6;
  }
  .rule-highlight {
    color: var(--orange);
    font-weight: 700;
  }
  .rules-note {
    text-align: center;
    font-size: 13px;
    color: var(--gray-400);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    padding: 20px;
    background: var(--dark-card);
    border: 1px solid var(--gray-600);
    border-radius: var(--radius);
  }
  @media (max-width: 768px) {
    .rules-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .rules-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="rules-grid">
    {% for block in section.blocks %}
      {% if block.type == 'rule' %}
        <div class="rule-card" {{ block.shopify_attributes }}>
          <div class="rule-icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.note != blank %}
    <div class="rules-note">
      {{ section.settings.note }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Match Rules",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "MATCH FORMAT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How We Play"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fast, fair, non-stop caged football."
    },
    {
      "type": "richtext",
      "id": "note",
      "label": "Footer Note"
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    }
  ],
  "blocks": [
    {
      "type": "rule",
      "name": "Rule Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "⚽"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "7 Players Per Team"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Including goalkeeper. Up to 4 substitutes per team."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Match Rules"
    }
  ]
}
{% endschema %}
