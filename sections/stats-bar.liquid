{% comment %} Stats Bar — Editable stats {% endcomment %}
<div class="stats-bar">
  {% for block in section.blocks %}
    <div class="stat" {{ block.shopify_attributes }}>
      <div class="stat-number">{{ block.settings.number }}</div>
      <div class="stat-label">{{ block.settings.label }}</div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Stats Bar",
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "7"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Courts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Bar",
      "blocks": [
        { "type": "stat", "settings": { "number": "7", "label": "Premium Courts" } },
        { "type": "stat", "settings": { "number": "5v5", "label": "& 7-a-Side" } },
        { "type": "stat", "settings": { "number": "24/7", "label": "Floodlit" } },
        { "type": "stat", "settings": { "number": "100%", "label": "All-Weather" } }
      ]
    }
  ]
}
{% endschema %}
