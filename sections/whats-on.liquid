{% comment %} What's On — Happening Now events, editable via Theme Editor {% endcomment %}
<div class="section-dark">
  <div class="section">
    <div class="section-label">{{ section.settings.label }}</div>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <p class="section-subtitle" style="margin-bottom:32px;">{{ section.settings.subheading }}</p>

    {% for block in section.blocks %}
      <div class="whats-on-card {% if block.settings.urgent %}urgent{% endif %}" {{ block.shopify_attributes }}>
        <div>
          <div style="font-weight:700;font-size:17px;margin-bottom:4px;">{{ block.settings.title }}</div>
          <div style="font-size:14px;color:var(--gray-400);">{{ block.settings.details }}</div>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <span class="whats-on-tag {{ block.settings.tag_style }}">{{ block.settings.tag_text }}</span>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="btn-primary" style="padding:10px 20px;font-size:13px;">{{ block.settings.link_text }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Whats On",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "HAPPENING NOW"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's On This Week"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From social kick-abouts to competitive leagues — there's something on every day."
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Event Name"
        },
        {
          "type": "textarea",
          "id": "details",
          "label": "Event Details",
          "default": "Day · Time · Price"
        },
        {
          "type": "text",
          "id": "tag_text",
          "label": "Tag Text",
          "default": "OPEN"
        },
        {
          "type": "select",
          "id": "tag_style",
          "label": "Tag Style",
          "options": [
            { "value": "tag-live", "label": "Green (Live/Open)" },
            { "value": "tag-limited", "label": "Orange (Limited/Hot)" },
            { "value": "tag-enrol", "label": "Green (Enrol)" },
            { "value": "tag-social", "label": "Blue (Social)" }
          ],
          "default": "tag-live"
        },
        {
          "type": "checkbox",
          "id": "urgent",
          "label": "Highlight (orange border)",
          "default": false
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Button Text",
          "default": "Book Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Whats On",
      "blocks": [
        {
          "type": "event",
          "settings": {
            "title": "Thursday Night Comp — Rulz Competitive",
            "details": "Thursday · 6:30 PM & 7:15 PM · $100/team/week · 10-week season",
            "tag_text": "LIVE NOW",
            "tag_style": "tag-limited",
            "urgent": true,
            "link": "/pages/competitions",
            "link_text": "View Ladder"
          }
        },
        {
          "type": "event",
          "settings": {
            "title": "Social Saturday — $10 Kick",
            "details": "Saturday · 10:00 AM – 4:00 PM · $10/person · All welcome, just rock up",
            "tag_text": "SOCIAL",
            "tag_style": "tag-social",
            "urgent": false,
            "link": "/pages/book-a-court",
            "link_text": "Details"
          }
        },
        {
          "type": "event",
          "settings": {
            "title": "Monday Junior Academy",
            "details": "Monday · 4:00 PM – 5:30 PM · $15/session · Ages 6–14",
            "tag_text": "ENROL",
            "tag_style": "tag-enrol",
            "urgent": false,
            "link": "/pages/academy",
            "link_text": "Enrol"
          }
        },
        {
          "type": "event",
          "settings": {
            "title": "Wednesday $10 Kick",
            "details": "Wednesday · 6:00 PM – 9:00 PM · $10/person · Casual 5-a-side",
            "tag_text": "OPEN",
            "tag_style": "tag-live",
            "urgent": false,
            "link": "/pages/book-a-court",
            "link_text": "Book Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
