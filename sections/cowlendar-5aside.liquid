{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
<!-- Cowlendar 5-a-Side Booking Calendar -->
<div class="section" id="booking-calendar-5aside">
  <div style="text-align:center;margin-bottom:32px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle" style="margin:0 auto;">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="cowlendar-embed">
    <div data-cowlendar-inline="6919c0739e502635e27acdae-44802415820853"></div>
  </div>

  {% if section.settings.note != blank %}
    <p style="text-align:center;margin-top:24px;font-size:13px;color:var(--gray-400);max-width:600px;margin-left:auto;margin-right:auto;">{{ section.settings.note }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "5-a-Side Calendar",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "BOOK NOW"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "5-a-Side Pitch Booking"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select your preferred date and time below. All bookings include balls and bibs."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Bottom note",
      "default": "All pitch bookings must be paid in full at the time of booking. We do not hold, reserve, or secure pitches without payment."
    },
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ]
}
{% endschema %}