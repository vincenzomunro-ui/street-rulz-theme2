{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Competition Ladder — Editable via Theme Editor {% endcomment %}
<div class="section">
  <div class="section-label">{{ section.settings.label }}</div>
  <h2 class="section-title">{{ section.settings.heading }}</h2>
  <p class="section-subtitle" style="margin-bottom:32px;">{{ section.settings.subheading }}</p>

  <div class="card ladder-wrap" style="overflow-x:auto;">
    <table class="ladder-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Team</th>
          <th>P</th>
          <th>W</th>
          <th>D</th>
          <th>L</th>
          <th>GF</th>
          <th>GA</th>
          <th>GD</th>
          <th>Pts</th>
        </tr>
      </thead>
      <tbody>
        {% for block in section.blocks %}
          <tr {{ block.shopify_attributes }}>
            <td>{{ forloop.index }}</td>
            <td class="team-name">{{ block.settings.team }}</td>
            <td>{{ block.settings.played }}</td>
            <td>{{ block.settings.wins }}</td>
            <td>{{ block.settings.draws }}</td>
            <td>{{ block.settings.losses }}</td>
            <td>{{ block.settings.goals_for }}</td>
            <td>{{ block.settings.goals_against }}</td>
            <td class="highlight">{{ block.settings.goal_diff }}</td>
            <td class="highlight">{{ block.settings.points }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if section.settings.updated_text != blank %}
    <p style="font-size:12px;color:var(--gray-600);margin-top:12px;text-align:right;">{{ section.settings.updated_text }}</p>
  {% endif %}
</div>

