{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
</style>
{% endif %}

<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <!-- Court Cards -->
  <div class="grid-2" style="gap:24px;margin-bottom:48px;">
    {% for block in section.blocks %}
      {% if block.type == 'court_card' %}
        <div class="card" style="padding:0;overflow:hidden;border:1px solid var(--gray-600);position:relative;" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}
            <div style="position:absolute;top:16px;right:16px;background:var(--orange);color:#fff;font-size:12px;font-weight:700;letter-spacing:1px;padding:6px 14px;border-radius:20px;z-index:2;text-transform:uppercase;">{{ block.settings.badge }}</div>
          {% endif %}
          <!-- Photo Spot -->
          <div style="width:100%;aspect-ratio:16/9;background:var(--gray-800);display:flex;align-items:center;justify-content:center;overflow:hidden;">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" style="width:100%;height:100%;object-fit:cover;">
            {% else %}
              <div style="text-align:center;color:var(--gray-400);font-size:13px;padding:20px;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="opacity:0.3;margin-bottom:8px;display:block;margin:0 auto 8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Upload photo in theme editor
              </div>
            {% endif %}
          </div>
          <div style="padding:24px;">
            <h3 style="font-family:'Archivo Black',sans-serif;font-size:22px;text-transform:uppercase;margin-bottom:4px;">{{ block.settings.title }}</h3>
            {% if block.settings.subtitle != blank %}
              <p style="color:var(--orange);font-size:14px;font-weight:600;letter-spacing:0.5px;margin-bottom:12px;">{{ block.settings.subtitle }}</p>
            {% endif %}
            <p style="color:var(--gray-400);font-size:14px;line-height:1.7;margin-bottom:16px;">{{ block.settings.description }}</p>
            <!-- Specs Grid -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;">
              {% if block.settings.spec_1 != blank %}
                <div style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--gray-200);">
                  <span style="color:var(--orange);font-size:16px;">✓</span> {{ block.settings.spec_1 }}
                </div>
              {% endif %}
              {% if block.settings.spec_2 != blank %}
                <div style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--gray-200);">
                  <span style="color:var(--orange);font-size:16px;">✓</span> {{ block.settings.spec_2 }}
                </div>
              {% endif %}
              {% if block.settings.spec_3 != blank %}
                <div style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--gray-200);">
                  <span style="color:var(--orange);font-size:16px;">✓</span> {{ block.settings.spec_3 }}
                </div>
              {% endif %}
              {% if block.settings.spec_4 != blank %}
                <div style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--gray-200);">
                  <span style="color:var(--orange);font-size:16px;">✓</span> {{ block.settings.spec_4 }}
                </div>
              {% endif %}
            </div>
            {% if block.settings.cta_text != blank %}
              <a href="{{ block.settings.cta_link }}" class="btn-primary" style="display:inline-block;margin-top:8px;">{{ block.settings.cta_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Courts Showcase",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "OUR FACILITY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "World-Class Caged Pitches"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "7 premium floodlit pitches built for fast, non-stop football."
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    }
  ],
  "blocks": [
    {
      "type": "court_card",
      "name": "Court Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Court Photo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "5-a-Side Pitches"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "6 PITCHES AVAILABLE"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (optional)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our premium 5-a-side caged pitches are perfect for fast-paced games."
        },
        {
          "type": "text",
          "id": "spec_1",
          "label": "Spec 1",
          "default": "Floodlit"
        },
        {
          "type": "text",
          "id": "spec_2",
          "label": "Spec 2",
          "default": "All-weather"
        },
        {
          "type": "text",
          "id": "spec_3",
          "label": "Spec 3",
          "default": "Caged walls"
        },
        {
          "type": "text",
          "id": "spec_4",
          "label": "Spec 4",
          "default": "Synthetic turf"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Courts Showcase"
    }
  ]
}
{% endschema %}
