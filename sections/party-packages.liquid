<!-- Party Packages Section -->
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle" style="margin:0 auto;">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="party-grid">
    {% for block in section.blocks %}
      <div class="party-card card {% if block.settings.highlighted %}card-highlight{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.badge != blank %}
          <div class="card-badge">{{ block.settings.badge }}</div>
        {% endif %}
        <h3 style="font-size:22px;font-weight:800;margin-bottom:4px;">{{ block.settings.title }}</h3>
        {% if block.settings.price != blank %}
          <div style="font-size:28px;font-weight:900;color:var(--orange);margin:12px 0;">{{ block.settings.price }}</div>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p style="font-size:14px;color:var(--gray-400);margin-bottom:20px;">{{ block.settings.subtitle }}</p>
        {% endif %}

        <div class="party-includes">
          {% if block.settings.include_1 != blank and block.settings.include_1 != "Party host 1 Hr" and block.settings.include_1 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_1 }}</div>
          {% endif %}
          {% if block.settings.include_2 != blank and block.settings.include_2 != "Party host 1 Hr" and block.settings.include_2 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_2 }}</div>
          {% endif %}
          {% if block.settings.include_3 != blank and block.settings.include_3 != "Party host 1 Hr" and block.settings.include_3 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_3 }}</div>
          {% endif %}
          {% if block.settings.include_4 != blank and block.settings.include_4 != "Party host 1 Hr" and block.settings.include_4 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_4 }}</div>
          {% endif %}
          {% if block.settings.include_5 != blank and block.settings.include_5 != "Party host 1 Hr" and block.settings.include_5 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_5 }}</div>
          {% endif %}
          {% if block.settings.include_6 != blank and block.settings.include_6 != "Party host 1 Hr" and block.settings.include_6 != "Mini tournament format" %}
            <div class="party-include-item">✓ {{ block.settings.include_6 }}</div>
          {% endif %}
        </div>

        {% if block.settings.cta_text != blank %}
          <a href="{{ block.settings.cta_link }}" class="btn-primary" style="width:100%;justify-content:center;margin-top:24px;">{{ block.settings.cta_text }}</a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.note != blank %}
    <p style="text-align:center;margin-top:32px;font-size:14px;color:var(--gray-400);max-width:600px;margin-left:auto;margin-right:auto;">{{ section.settings.note }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Party Packages",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "PARTY PACKAGES" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose Your Party Package" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "The ultimate football birthday experience for kids and adults on the Gold Coast." },
    { "type": "textarea", "id": "note", "label": "Bottom note" }
  ],
  "blocks": [
    {
      "type": "package",
      "name": "Package",
      "settings": [
        { "type": "text", "id": "title", "label": "Package name" },
        { "type": "text", "id": "price", "label": "Price" },
        { "type": "text", "id": "subtitle", "label": "Subtitle/duration" },
        { "type": "text", "id": "badge", "label": "Badge text" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight this card", "default": false },
        { "type": "text", "id": "include_1", "label": "Included item 1" },
        { "type": "text", "id": "include_2", "label": "Included item 2" },
        { "type": "text", "id": "include_3", "label": "Included item 3" },
        { "type": "text", "id": "include_4", "label": "Included item 4" },
        { "type": "text", "id": "include_5", "label": "Included item 5" },
        { "type": "text", "id": "include_6", "label": "Included item 6" },
        { "type": "text", "id": "cta_text", "label": "Button text", "default": "Book This Package" },
        { "type": "url", "id": "cta_link", "label": "Button link" }
      ]
    }
  ]
}
{% endschema %}
