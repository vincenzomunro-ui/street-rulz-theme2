{% comment %}
  Product Tiers — Displays 3-4 Shopify products as pricing tier cards.
  Each card shows the product title, price, description, and inventory status.
  When a product variant's inventory reaches 0, the card grays out and shows "SOLD OUT".
  Used on tiered-pricing event pages like Holiday Clinics.
{% endcomment %}

{% if section.settings.bg_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .tier-product-card {
    background-color: {{ section.settings.card_color }};
  }
  {% endif %}
</style>
{% endif %}

<style>
  .product-tiers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    max-width: 1000px;
    margin: 0 auto 32px;
  }
  @media (max-width: 600px) {
    .product-tiers-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
  }
  @media (max-width: 380px) {
    .product-tiers-grid {
      grid-template-columns: 1fr;
    }
  }
  .tier-product-card {
    background: #2b2b2b;
    border-radius: 12px;
    padding: 28px 20px;
    text-align: center;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 2px solid transparent;
  }
  .tier-product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .tier-product-card.highlighted {
    border-color: var(--orange, #ff6600);
  }
  .tier-product-card.sold-out {
    opacity: 0.45;
    pointer-events: none;
    filter: grayscale(60%);
  }
  .tier-product-card.sold-out:hover {
    transform: none;
    box-shadow: none;
  }
  .tier-badge {
    display: inline-block;
    background: var(--orange, #ff6600);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .tier-sold-badge {
    display: inline-block;
    background: #666;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .tier-product-card .tier-name {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #fff;
  }
  .tier-product-card .tier-price {
    font-size: 36px;
    font-weight: 800;
    color: var(--orange, #ff6600);
    margin-bottom: 4px;
    line-height: 1.1;
  }
  .tier-product-card.sold-out .tier-price {
    color: #666;
    text-decoration: line-through;
  }
  .tier-product-card .tier-unit {
    font-size: 13px;
    color: #999;
    margin-bottom: 16px;
  }
  .tier-product-card .tier-desc {
    font-size: 13px;
    color: #aaa;
    margin-bottom: 16px;
    line-height: 1.4;
  }
  .tier-product-card .tier-spots {
    font-size: 12px;
    font-weight: 600;
    color: #888;
  }
  .tier-product-card .tier-spots.low-stock {
    color: var(--orange, #ff6600);
  }
  .tier-product-card .tier-cta {
    display: inline-block;
    background: var(--orange, #ff6600);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 10px 24px;
    border-radius: 8px;
    text-decoration: none;
    margin-top: 16px;
    transition: background 0.2s;
  }
  .tier-product-card .tier-cta:hover {
    background: #e55a00;
  }
  .tier-product-card.sold-out .tier-cta {
    display: none;
  }
</style>

<div class="section" style="padding:60px 20px;">
  <div style="text-align:center;margin-bottom:40px;">
    {% if section.settings.label != blank %}
      <p class="section-label">{{ section.settings.label }}</p>
    {% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle" style="max-width:640px;margin:0 auto;">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="product-tiers-grid">
    {% for block in section.blocks %}
      {% if block.type == 'product_tier' %}
        {% assign tier_product = block.settings.product %}
        {% assign is_sold_out = false %}
        {% assign inventory_count = 0 %}
        {% assign has_inventory = false %}

        {% if tier_product != blank %}
          {% comment %} Check inventory across all variants {% endcomment %}
          {% for variant in tier_product.variants %}
            {% if variant.inventory_management == 'shopify' %}
              {% assign has_inventory = true %}
              {% assign inventory_count = inventory_count | plus: variant.inventory_quantity %}
            {% endif %}
          {% endfor %}

          {% if has_inventory and inventory_count <= 0 %}
            {% assign is_sold_out = true %}
          {% endif %}
        {% endif %}

        <div class="tier-product-card{% if block.settings.highlighted %} highlighted{% endif %}{% if is_sold_out %} sold-out{% endif %}" {{ block.shopify_attributes }}>
          {% if is_sold_out %}
            <div class="tier-sold-badge">SOLD OUT</div>
          {% elsif block.settings.badge != blank %}
            <div class="tier-badge">{{ block.settings.badge }}</div>
          {% endif %}

          <h3 class="tier-name">
            {% if block.settings.tier_label != blank %}
              {{ block.settings.tier_label }}
            {% elsif tier_product != blank %}
              {{ tier_product.title }}
            {% else %}
              Pricing Tier
            {% endif %}
          </h3>

          <p class="tier-price">
            {% if tier_product != blank %}
              {{ tier_product.price | money }}
            {% elsif block.settings.fallback_price != blank %}
              {{ block.settings.fallback_price }}
            {% endif %}
          </p>

          {% if block.settings.price_unit != blank %}
            <p class="tier-unit">{{ block.settings.price_unit }}</p>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="tier-desc">{{ block.settings.description }}</p>
          {% endif %}

          {% if has_inventory and is_sold_out == false %}
            <p class="tier-spots{% if inventory_count <= 2 %} low-stock{% endif %}">
              {% if inventory_count == 1 %}
                1 spot left!
              {% else %}
                {{ inventory_count }} spots available
              {% endif %}
            </p>
          {% elsif is_sold_out %}
            <p class="tier-spots">All spots taken</p>
          {% elsif block.settings.spots_text != blank %}
            <p class="tier-spots">{{ block.settings.spots_text }}</p>
          {% endif %}

          {% if tier_product != blank and is_sold_out == false %}
            <a href="{{ tier_product.url }}" class="tier-cta">
              {% if block.settings.cta_text != blank %}
                {{ block.settings.cta_text }}
              {% else %}
                Register →
              {% endif %}
            </a>
          {% elsif block.settings.fallback_link != blank and is_sold_out == false %}
            <a href="{{ block.settings.fallback_link }}" class="tier-cta">
              {% if block.settings.cta_text != blank %}
                {{ block.settings.cta_text }}
              {% else %}
                Register →
              {% endif %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.note != blank %}
    <p style="text-align:center;font-size:13px;color:#888;max-width:600px;margin:0 auto;">{{ section.settings.note }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Product Tiers",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "PRICING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose Your Entry" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Lock in the cheapest price — tiers sell out in order." },
    { "type": "textarea", "id": "note", "label": "Bottom Note (optional)" },
    { "type": "header", "content": "Section Colors" },
    { "type": "text", "id": "bg_color", "label": "Background Color" },
    { "type": "text", "id": "card_color", "label": "Card Color" }
  ],
  "blocks": [
    {
      "type": "product_tier",
      "name": "Pricing Tier",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify Product", "info": "Select the product for this tier. Inventory is checked automatically." },
        { "type": "text", "id": "tier_label", "label": "Tier Label Override", "info": "Override the product title with a custom label (e.g. Early Bird 1)" },
        { "type": "text", "id": "fallback_price", "label": "Fallback Price", "info": "Shown if no product is selected (e.g. $10)" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Limited spots available" },
        { "type": "text", "id": "price_unit", "label": "Price Unit", "default": "per team" },
        { "type": "text", "id": "spots_text", "label": "Spots Text (fallback)", "info": "Shown if product has no inventory tracking" },
        { "type": "text", "id": "badge", "label": "Badge (optional)", "info": "e.g. CHEAPEST, BEST VALUE" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight this tier", "default": false },
        { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Register →" },
        { "type": "url", "id": "fallback_link", "label": "Fallback Link", "info": "Used if no product is selected" }
      ]
    }
  ],
  "presets": [{ "name": "Product Tiers" }]
}
{% endschema %}
