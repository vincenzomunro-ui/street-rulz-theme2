{% comment %} CTA Banner — Editable via Theme Editor {% endcomment %}
<div class="section">
  <div class="cta-banner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    <div class="btn-row">
      {% if section.settings.cta1_text != blank %}
        <a href="{{ section.settings.cta1_link }}" class="btn-primary">{{ section.settings.cta1_text }}</a>
      {% endif %}
      {% if section.settings.cta2_text != blank %}
        <a href="{{ section.settings.cta2_link }}" class="btn-secondary">{{ section.settings.cta2_text }}</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Play?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Book a pitch in 60 seconds or get in touch to organise your next event."
    },
    {
      "type": "text",
      "id": "cta1_text",
      "label": "Button 1 Text",
      "default": "Book a Pitch"
    },
    {
      "type": "url",
      "id": "cta1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Button 2 Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
