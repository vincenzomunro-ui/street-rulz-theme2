{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .rule-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  <div class="grid-2" style="gap:24px;">
    {% for block in section.blocks %}
      {% if block.type == 'rule_card' %}
        <div class="rule-card card" style="padding:24px;" {{ block.shopify_attributes }}>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <span style="font-size:20px;">{{ block.settings.icon }}</span>
            <h3 style="font-size:16px;font-weight:700;margin:0;">{{ block.settings.title }}</h3>
          </div>
          <p style="font-size:14px;color:var(--gray-400);line-height:1.7;">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "Rules Info",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "RULES" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Match Rules & Format" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need to know before game night." },
    { "type": "header", "content": "Section Colors" },
    { "type": "text", "id": "bg_color", "label": "Background Color" },
    { "type": "text", "id": "text_color", "label": "Text Color" },
    { "type": "text", "id": "card_color", "label": "Card Color" }
  ],
  "blocks": [
    {
      "type": "rule_card",
      "name": "Rule Card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon/Emoji", "default": "⏱️" },
        { "type": "text", "id": "title", "label": "Title", "default": "Match Duration" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Juniors: 18 min each way (36 min total). Youth & Seniors: 20 min each way (40 min total)." }
      ]
    }
  ],
  "presets": [{ "name": "Rules Info" }]
}
{% endschema %}
