{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
</style>
{% endif %}
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  <div style="max-width:680px;margin:0 auto;position:relative;padding-left:40px;">
    <div style="position:absolute;left:15px;top:0;bottom:0;width:2px;background:var(--orange);opacity:0.3;"></div>
    {% for block in section.blocks %}
      {% if block.type == 'milestone' %}
        <div style="position:relative;margin-bottom:32px;" {{ block.shopify_attributes }}>
          <div style="position:absolute;left:-33px;top:4px;width:12px;height:12px;border-radius:50%;background:var(--orange);border:2px solid var(--bg-dark,#181a19);"></div>
          <p style="font-size:12px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">{{ block.settings.date }}</p>
          <h4 style="font-size:16px;font-weight:700;margin-bottom:6px;">{{ block.settings.title }}</h4>
          <p style="font-size:14px;color:var(--gray-400);line-height:1.6;">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "Season Timeline",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "ROADMAP" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Season Launch Timeline" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Key dates for the upcoming RULZ expansion." },
    { "type": "header", "content": "Section Colors" },
    { "type": "text", "id": "bg_color", "label": "Background Color" },
    { "type": "text", "id": "text_color", "label": "Text Color" }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        { "type": "text", "id": "date", "label": "Date", "default": "Week 1 — 5 Mar" },
        { "type": "text", "id": "title", "label": "Title", "default": "Confirm Pricing & Build Products" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Finalise pricing, build Shopify product pages, draft outreach." }
      ]
    }
  ],
  "presets": [{ "name": "Season Timeline" }]
}
{% endschema %}
