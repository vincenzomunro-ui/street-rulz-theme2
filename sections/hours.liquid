{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Opening Hours — Editable via Theme Editor {% endcomment %}
<div class="section">
  <div class="section-label">{{ section.settings.label }}</div>
  <h2 class="section-title">{{ section.settings.heading }}</h2>

  <div class="hours-grid">
    {% for block in section.blocks %}
      <div class="hours-item" {{ block.shopify_attributes }}>
        <span class="day">{{ block.settings.day }}</span>
        <span class="time">{{ block.settings.time }}</span>
      </div>
    {% endfor %}
  </div>

  {% if section.settings.note != blank %}
    <p style="text-align:center;margin-top:24px;font-size:15px;color:var(--orange);font-weight:600;">{{ section.settings.note }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Opening Hours",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "OPENING HOURS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "When We're Open"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note (e.g. Open by Appointment)",
      "default": "Open by Appointment"
    },
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ],
  "blocks": [
    {
      "type": "hours_row",
      "name": "Day",
      "settings": [
        {
          "type": "text",
          "id": "day",
          "label": "Day",
          "default": "Monday"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Hours",
          "default": "8:00 AM \u2013 10:00 PM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Opening Hours",
      "blocks": [
        {
          "type": "hours_row",
          "settings": {
            "day": "Monday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Tuesday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Wednesday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Thursday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Friday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Saturday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        },
        {
          "type": "hours_row",
          "settings": {
            "day": "Sunday",
            "time": "8:00 AM \u2013 10:00 PM"
          }
        }
      ]
    }
  ]
}
{% endschema %}