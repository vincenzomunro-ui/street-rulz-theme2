{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .tier-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle" style="max-width:640px;margin:0 auto;">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  <!-- Event Details Row -->
  <div style="display:flex;justify-content:center;gap:32px;flex-wrap:wrap;margin-bottom:40px;">
    {% if section.settings.event_date != blank %}
      <div style="text-align:center;">
        <span style="font-size:24px;">📅</span>
        <p style="font-size:14px;font-weight:600;color:var(--orange);margin-top:4px;">{{ section.settings.event_date }}</p>
      </div>
    {% endif %}
    {% if section.settings.event_time != blank %}
      <div style="text-align:center;">
        <span style="font-size:24px;">⏰</span>
        <p style="font-size:14px;font-weight:600;color:var(--orange);margin-top:4px;">{{ section.settings.event_time }}</p>
      </div>
    {% endif %}
    {% if section.settings.event_ages != blank %}
      <div style="text-align:center;">
        <span style="font-size:24px;">👦</span>
        <p style="font-size:14px;font-weight:600;color:var(--orange);margin-top:4px;">{{ section.settings.event_ages }}</p>
      </div>
    {% endif %}
    {% if section.settings.event_teams != blank %}
      <div style="text-align:center;">
        <span style="font-size:24px;">🏆</span>
        <p style="font-size:14px;font-weight:600;color:var(--orange);margin-top:4px;">{{ section.settings.event_teams }}</p>
      </div>
    {% endif %}
  </div>
  <!-- Pricing Tiers -->
  {% if section.blocks.size > 0 %}
    <div class="grid-3" style="gap:24px;margin-bottom:32px;">
      {% for block in section.blocks %}
        {% if block.type == 'tier' %}
          <div class="tier-card card" style="padding:28px;text-align:center;{% if block.settings.highlighted %}border:2px solid var(--orange);{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.badge != blank %}
              <div class="card-badge" style="margin-bottom:12px;">{{ block.settings.badge }}</div>
            {% endif %}
            <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">{{ block.settings.tier_name }}</h3>
            <p style="font-size:32px;font-weight:800;color:var(--orange);margin-bottom:4px;">{{ block.settings.price }}</p>
            <p style="font-size:13px;color:var(--gray-400);margin-bottom:16px;">{{ block.settings.description }}</p>
            {% if block.settings.spots != blank %}
              <p style="font-size:12px;color:var(--gray-500);font-weight:600;margin-bottom:16px;">{{ block.settings.spots }}</p>
            {% endif %}
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="btn-primary" style="display:inline-block;font-size:14px;padding:12px 28px;margin-top:8px;text-decoration:none;">
                {% if block.settings.button_text != blank %}{{ block.settings.button_text }}{% else %}Book Now{% endif %} &rarr;
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
  {% if section.settings.cta_text != blank %}
    <div style="text-align:center;">
      <a href="{{ section.settings.cta_link }}" class="btn-primary" style="font-size:16px;padding:14px 40px;">{{ section.settings.cta_text }} →</a>
    </div>
  {% endif %}
</div>
{% schema %}
{
  "name": "Event Hero",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "EVENT" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "RULZ Junior Fiesta" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "One-day carnival — fast 5-a-side games, medals, fun challenges." },
    { "type": "text", "id": "event_date", "label": "Event Date", "default": "Sunday 29 March 2026" },
    { "type": "text", "id": "event_time", "label": "Event Time", "default": "8:00am – 2:00pm" },
    { "type": "text", "id": "event_ages", "label": "Ages", "default": "U7 – U13" },
    { "type": "text", "id": "event_teams", "label": "Team Cap", "default": "32 Teams Max" },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Register Your Team" },
    { "type": "url", "id": "cta_link", "label": "CTA Button Link" },
    { "type": "header", "content": "Section Colors" },
    { "type": "text", "id": "bg_color", "label": "Background Color" },
    { "type": "text", "id": "text_color", "label": "Text Color" },
    { "type": "text", "id": "card_color", "label": "Card Color" }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Pricing Tier",
      "settings": [
        { "type": "text", "id": "tier_name", "label": "Tier Name", "default": "Early Bird" },
        { "type": "text", "id": "price", "label": "Price", "default": "$55" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "First 12 teams — limited spots" },
        { "type": "text", "id": "spots", "label": "Spots Info", "default": "12 spots only" },
        { "type": "text", "id": "badge", "label": "Badge (optional)" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight this tier", "default": false },
        { "type": "url", "id": "link", "label": "Product Link", "info": "Link to the Shopify product page for this tier" },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "Book Now" }
      ]
    }
  ],
  "presets": [{ "name": "Event Hero" }]
}
{% endschema %}
