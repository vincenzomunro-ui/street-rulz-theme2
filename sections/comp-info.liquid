<!-- Competition Info Section -->
<div class="section">
  <div style="text-align:center;margin-bottom:48px;">
    <p class="section-label">{{ section.settings.label }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subtitle" style="margin:0 auto;">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="comp-info-grid">
    {% for block in section.blocks %}
      <div class="comp-info-card card" {{ block.shopify_attributes }}>
        <div class="comp-info-icon">{{ block.settings.icon }}</div>
        <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">{{ block.settings.title }}</h3>
        <p style="font-size:14px;color:var(--gray-400);line-height:1.7;">{{ block.settings.description }}</p>
        {% if block.settings.detail != blank %}
          <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--gray-800);">
            <span style="font-size:13px;font-weight:700;color:var(--orange);">{{ block.settings.detail }}</span>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.majesty_heading != blank %}
    <div style="text-align:center;margin-top:56px;">
      <h3 class="section-title" style="font-size:28px;">{{ section.settings.majesty_heading }}</h3>
      {% if section.settings.majesty_description != blank %}
        <p style="font-size:15px;color:var(--gray-400);max-width:560px;margin:0 auto 24px;line-height:1.7;">{{ section.settings.majesty_description }}</p>
      {% endif %}
      {% if section.settings.majesty_link != blank %}
        <a href="{{ section.settings.majesty_link }}" target="_blank" class="btn-primary">{{ section.settings.majesty_button_text }} →</a>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Competition Info",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "COMPETITIONS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How Our Comps Work" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "10-week seasons with graded divisions for all skill levels." },
    { "type": "text", "id": "majesty_heading", "label": "Majesty section heading", "default": "Register Your Team" },
    { "type": "textarea", "id": "majesty_description", "label": "Majesty section description", "default": "Team registrations and fixtures are managed through Majesty. Click below to register your team, view fixtures, or check results." },
    { "type": "url", "id": "majesty_link", "label": "Majesty registration link" },
    { "type": "text", "id": "majesty_button_text", "label": "Majesty button text", "default": "Register on Majesty" }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon/emoji", "default": "⚽" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "detail", "label": "Detail/highlight text" }
      ]
    }
  ]
}
{% endschema %}
