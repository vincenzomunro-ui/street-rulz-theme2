{% if section.settings.bg_color != blank or section.settings.text_color != blank %}
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }} !important;{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }} !important;{% endif %}
  }
  {% if section.settings.card_color != blank %}
  #shopify-section-{{ section.id }} .card,
  #shopify-section-{{ section.id }} .service-card,
  #shopify-section-{{ section.id }} .pitch-select-card,
  #shopify-section-{{ section.id }} .time-slot-card,
  #shopify-section-{{ section.id }} .booking-info-item,
  #shopify-section-{{ section.id }} .academy-schedule-box,
  #shopify-section-{{ section.id }} .party-card,
  #shopify-section-{{ section.id }} .cowlendar-embed,
  #shopify-section-{{ section.id }} .step-card {
    background-color: {{ section.settings.card_color }} !important;
  }
  {% endif %}
</style>
{% endif %}
{% comment %} Main Collection — Lists products in a collection {% endcomment %}
<div class="section">
  <h1 class="section-title">{{ collection.title }}</h1>
  {% if collection.description != blank %}
    <p class="section-subtitle" style="margin-bottom:32px;">{{ collection.description }}</p>
  {% endif %}
  <div class="grid-3">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="card" style="text-decoration:none;">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" style="border-radius:8px;margin-bottom:16px;">
        {% endif %}
        <h3 style="font-size:16px;font-weight:700;margin-bottom:8px;">{{ product.title }}</h3>
        <p style="color:var(--orange);font-weight:700;">{{ product.price | money }}</p>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors (leave blank for defaults)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card/Tile Color"
    }
  ]
}
{% endschema %}