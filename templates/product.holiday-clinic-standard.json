{
  "sections": {
    "main": {
      "type": "main-product",
      "settings": {}
    },
    "standard_info": {
      "type": "custom",
      "settings": {
        "heading": "Standard Rate",
        "content": "$70 per day | Choose your date | 9:00am - 1:30pm\n\nFlexibility to pick the day that works best for your child"
      }
    },
    "date_selector": {
      "type": "custom",
      "settings": {
        "heading": "Select Your Date",
        "description": "Choose which day works best for your child",
        "options": [
          {
            "label": "Friday 10 April",
            "value": "april-10"
          },
          {
            "label": "Friday 17 April",
            "value": "april-17"
          }
        ]
      }
    },
    "parent_info": {
      "type": "custom",
      "settings": {
        "heading": "Parent/Guardian Information",
        "description": "We need your contact details for confirmation and emergency purposes",
        "fields": [
          {
            "label": "Parent/Guardian Name",
            "type": "text",
            "required": true
          },
          {
            "label": "Email Address",
            "type": "email",
            "required": true
          },
          {
            "label": "Phone Number",
            "type": "tel",
            "required": true
          },
          {
            "label": "Emergency Contact Number (if different)",
            "type": "tel",
            "required": false
          }
        ]
      }
    },
    "child_info": {
      "type": "custom",
      "settings": {
        "heading": "Child Information",
        "description": "Tell us about the participant",
        "fields": [
          {
            "label": "Child's Full Name",
            "type": "text",
            "required": true
          },
          {
            "label": "Age",
            "type": "select",
            "required": true,
            "options": [
              "5 years",
              "6 years",
              "7 years",
              "8 years",
              "9 years",
              "10 years",
              "11 years",
              "12 years",
              "13 years"
            ]
          },
          {
            "label": "Date of Birth",
            "type": "date",
            "required": false
          }
        ]
      }
    },
    "medical_info": {
      "type": "custom",
      "settings": {
        "heading": "Health & Medical Information",
        "description": "Help us keep your child safe",
        "fields": [
          {
            "label": "Any allergies or medical conditions we should know about?",
            "type": "textarea",
            "required": false,
            "placeholder": "e.g., asthma, nut allergy, diabetes, etc."
          },
          {
            "label": "Any medications your child takes regularly?",
            "type": "textarea",
            "required": false
          },
          {
            "label": "Any other health concerns?",
            "type": "textarea",
            "required": false
          }
        ]
      }
    },
    "experience_level": {
      "type": "custom",
      "settings": {
        "heading": "Football Experience",
        "description": "Help us place your child in the right group",
        "field": {
          "label": "What's your child's experience with football?",
          "type": "select",
          "required": true,
          "options": [
            "Beginner (no experience)",
            "Some experience (played casually)",
            "Regular player (plays weekly)",
            "Advanced (competitive/school team)"
          ]
        }
      }
    },
    "add_ons": {
      "type": "custom",
      "settings": {
        "heading": "Optional Add-ons",
        "description": "Enhance the experience",
        "options": [
          {
            "label": "Player Fuel Pack - $15 (snacks & drinks for this day)",
            "value": "fuel-pack",
            "price": 15
          }
        ]
      }
    },
    "extra_requirements": {
      "type": "custom",
      "settings": {
        "heading": "Any Special Requirements?",
        "description": "Let us know if there's anything else we should be aware of",
        "field": {
          "label": "Special requests or requirements",
          "type": "textarea",
          "required": false,
          "placeholder": "e.g., dietary restrictions, mobility support, learning support, etc."
        }
      }
    },
    "what_to_bring": {
      "type": "custom",
      "settings": {
        "heading": "What to Bring",
        "content": "✓ Indoor football boots or trainers\n✓ Shin pads\n✓ Water bottle\n✓ Comfortable clothes\n✓ Towel\n\nWe provide everything else!"
      }
    },
    "terms": {
      "type": "custom",
      "settings": {
        "heading": "Terms & Conditions",
        "description": "By booking, you agree to our terms",
        "checkbox": {
          "label": "I agree to the cancellation policy (24-hour notice required) and code of conduct",
          "required": true
        }
      }
    },
    "cta": {
      "type": "custom",
      "settings": {
        "heading": "Ready to Book?",
        "button_text": "Complete Booking - $70",
        "button_color": "#ff6b35"
      }
    }
  },
  "order": [
    "main",
    "standard_info",
    "date_selector",
    "parent_info",
    "child_info",
    "medical_info",
    "experience_level",
    "add_ons",
    "extra_requirements",
    "what_to_bring",
    "terms",
    "cta"
  ]
}
