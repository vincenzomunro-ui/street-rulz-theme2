<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | default: '7 premium cage football pitches at Tallebudgera, Gold Coast. Book a pitch, join a league, host a birthday party, or book a holiday clinic. Play rain or shine.' }}">
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

<!-- Announcement Bar -->
{% section 'announcement-bar' %}

<!-- Navigation -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="Street Rulz Football" class="nav-logo-img">
    </a>
    <ul class="nav-links">
      {% for link in linklists.main-menu.links %}
        {% if link.links.size > 0 %}
          <li class="nav-dropdown">
            <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %} style="display:inline-flex;align-items:center;gap:3px;">{{ link.title }}<svg width="8" height="5" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" style="flex-shrink:0;"><path d="M1 1l4 4 4-4"/></svg></a>
            <ul class="nav-dropdown-menu">
              {% for child in link.links %}
                <li><a href="{{ child.url }}">{{ child.title }}</a></li>
              {% endfor %}
            </ul>
          </li>
        {% else %}
          <li><a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
    <div class="nav-right">
      <a href="/cart" class="nav-cart" title="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <a href="/pages/book-a-court" class="nav-cta">Book Now</a>
    </div>
    <button class="nav-toggle" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-logo">
    <img src="{{ 'logo.png' | asset_url }}" alt="Street Rulz Football" style="width:80px;height:80px;object-fit:contain;margin:0 auto 16px;display:block;">
  </div>
  {% for link in linklists.main-menu.links %}
    {% if link.links.size > 0 %}
      <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %} style="font-weight:700;">{{ link.title }}</a>
      <div style="padding-left:16px;display:flex;flex-direction:column;gap:4px;margin-bottom:8px;">
        {% for child in link.links %}
          <a href="{{ child.url }}" style="font-size:14px;color:var(--gray-400);">{{ child.title }}</a>
        {% endfor %}
      </div>
    {% else %}
      <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a>
    {% endif %}
  {% endfor %}
  <a href="/cart" class="mobile-cart-link">Cart {% if cart.item_count > 0 %}({{ cart.item_count }}){% endif %}</a>
  <a href="/pages/book-a-court" class="nav-cta">Book Now</a>
</div>

<!-- Main Content -->
{{ content_for_layout }}

<!-- Footer -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="{{ 'logo.png' | asset_url }}" alt="Street Rulz Football" class="footer-logo">
      <h3>Street Rulz Football</h3>
      <p>Gold Coast's home of cage football. 7 premium enclosed pitches at Tallebudgera. Play rain or shine.</p>
      <div class="social-links">
        <a href="https://www.facebook.com/StreetRulzFootball/" target="_blank" class="social-link" title="Facebook">
          <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/streetrulz_football/" target="_blank" class="social-link" title="Instagram">
          <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
      <p style="margin-top:12px;font-size:13px;color:var(--gray-600);">ABN: 60 728 302 749</p>
    </div>
    <div class="footer-col">
      <h4>Play</h4>
      <a href="/pages/book-a-court">Book a Pitch</a>
      <a href="/pages/competitions">Leagues</a>
      <a href="/pages/birthday-parties">Birthday Parties</a>
      <a href="/pages/events">Events</a>
    </div>
    <div class="footer-col">
      <h4>Info</h4>
      <a href="/pages/about-us">About Us</a>
      <a href="/pages/contact">Contact Us</a>
      <div style="margin-top: 12px; margin-bottom: 12px;">
        <a href="tel:+61412766696" style="display: block; font-weight: 700; font-size: 16px; color: #FF7F30;">Vincenzo: 0412 766 696</a>
      </div>
      <a href="mailto:admin@rulz.com.au" style="margin-top: 12px; display: block;">admin@rulz.com.au</a>
      <a href="https://www.google.com/maps/dir//Street+Rulz+Football,+40+Andrews+Rd,+Tallebudgera+QLD+4228,+Australia" target="_blank">Get Directions</a>
    </div>
    <div class="footer-col">
      <h4>Social</h4>
      <a href="https://www.facebook.com/StreetRulzFootball/" target="_blank">Facebook</a>
      <a href="https://www.instagram.com/streetrulz_football/" target="_blank">Instagram</a>
      <a href="https://wa.me/61412766696" target="_blank">WhatsApp</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {{ 'now' | date: '%Y' }} Street Rulz Football LTD PTY — The Trustee for Munro Family Trust</p>
    <p>40 Andrews Road, Tallebudgera QLD 4228</p>
  </div>
</footer>

<!-- Floating Buttons -->
<div class="floating-btns">
  <a href="tel:+61412766696" class="float-btn float-phone" title="Call Us">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
  </a>
  <a href="https://www.instagram.com/streetrulz_football/" target="_blank" class="float-btn float-instagram" title="Instagram">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
  </a>
</div>

<!-- Mobile Sticky CTA -->
<div class="mobile-cta">
  <a href="/pages/book-a-court">Book a Pitch — From $110/hr</a>
</div>

<!-- Cowlendar Booking Widget -->
<script src="https://app.cowlendar.com/js/sdk.js" defer></script>

<script src="{{ 'main.js' | asset_url }}" defer></script>

<!-- Relocate Cowlendar subscription widget on Academy page -->
<script src="{{ 'academy-widget.js' | asset_url }}" defer></script>
</body>
</html>
