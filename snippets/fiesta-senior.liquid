{% comment %}
  Senior Fiesta Product — Men's Open, Women's, Mixed divisions.
  Fields: Team Name, Captain Name, Phone, Player Count, Division, Email.
  All fields required.
{% endcomment %}
<div class="section">
  <h1 class="section-title">{{ product.title }}</h1>
  <div style="max-width:720px;font-size:16px;color:var(--gray-200);line-height:1.8;">
    {{ product.description }}
  </div>
  {% if product.available %}
    {% form 'product', product, class: 'vtls-exclude-atc-injector' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <div style="margin-top:24px;max-width:480px;">
        {%- comment -%} Team Name — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="team-name" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Team Name <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="text"
            id="team-name"
            name="properties[Team Name]"
            placeholder="e.g. The Strikers"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            Make sure all your teammates enter the same team name so we can group you together.
          </p>
        </div>

        {%- comment -%} Team Captain Name — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="captain-name" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Team Captain Name <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="text"
            id="captain-name"
            name="properties[Captain Name]"
            placeholder="e.g. John Smith"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            Primary contact for your team.
          </p>
        </div>

        {%- comment -%} Contact Phone — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="contact-phone" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Contact Phone <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="tel"
            id="contact-phone"
            name="properties[Contact Phone]"
            placeholder="e.g. 0412 345 678"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Division (Men's/Women's/Mixed) — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="division" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Division <span style="color:var(--orange);">*</span>
          </label>
          <select
            id="division"
            name="properties[Division]"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;appearance:auto;cursor:pointer;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
            <option value="" disabled selected>Select division</option>
            <option value="Men's Open">Men's Open</option>
            <option value="Women's">Women's</option>
            <option value="Mixed">Mixed</option>
          </select>
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            Which division does your team want to enter?
          </p>
        </div>

        {%- comment -%} Number of Players — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="player-count" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Number of Players <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="number"
            id="player-count"
            name="properties[Player Count]"
            placeholder="e.g. 12"
            min="6"
            max="20"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            6–20 players registered.
          </p>
        </div>

        {%- comment -%} Email Address — Required {%- endcomment -%}
        <div style="margin-bottom:24px;">
          <label for="customer-email" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Email Address <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="email"
            id="customer-email"
            name="properties[Email]"
            placeholder="e.g. john@example.com"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            We'll send event updates, draw info, and confirmation to this email.
          </p>
        </div>
      </div>

      <button type="submit" class="btn-primary" style="margin-top:8px;">
        Add to Cart — {{ product.price | money }}
      </button>
    {% endform %}
  {% else %}
    <p style="margin-top:24px;font-size:18px;color:var(--orange);font-weight:700;">Sold Out</p>
  {% endif %}
</div>
