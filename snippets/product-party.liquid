{% comment %} Party Product — with booking fields + food package for premium packages {% endcomment %}

{% comment %} Detect package type by product handle {% endcomment %}
{% assign is_premium = false %}
{% assign pizza_count = 0 %}
{% assign drink_count = 0 %}
{% assign package_type = 'base' %}

{% if product.handle contains 'vip' %}
  {% assign is_premium = true %}
  {% assign pizza_count = 7 %}
  {% assign drink_count = 8 %}
  {% assign package_type = 'vip' %}
{% elsif product.handle contains 'ultimate' or product.handle contains 'epic' %}
  {% assign is_premium = true %}
  {% assign pizza_count = 5 %}
  {% assign drink_count = 6 %}
  {% assign package_type = 'epic' %}
{% else %}
  {% assign pizza_count = 4 %}
  {% assign drink_count = 4 %}
  {% assign package_type = 'base' %}
{% endif %}

<div class="section">
  <h1 class="section-title">
    {{ product.title }}
    {% if is_premium %}
      <span style="display:inline-block;background:var(--orange);color:var(--black,#000);font-size:12px;font-weight:700;padding:4px 10px;border-radius:20px;margin-left:10px;vertical-align:middle;letter-spacing:0.5px;"> Food Package Included</span>
    {% endif %}
  </h1>
  <div style="max-width:720px;font-size:16px;color:var(--gray-200);line-height:1.8;">
    {{ product.description }}
  </div>
  {% if product.available %}
    {% form 'product', product, class: 'vtls-exclude-atc-injector' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <div style="margin-top:24px;max-width:480px;">
        {%- comment -%} Parent / Guardian Name — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="parent-name" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Parent / Guardian Name <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="text"
            id="parent-name"
            name="properties[Parent Name]"
            placeholder="e.g. Sarah Smith"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Birthday Child's Name — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="child-name" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Birthday Child's Name <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="text"
            id="child-name"
            name="properties[Child Name]"
            placeholder="e.g. Jack"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Preferred Date — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="party-date" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Preferred Date <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="date"
            id="party-date"
            name="properties[Preferred Date]"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;color-scheme:dark;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            We'll confirm availability and get back to you within 24 hours.
          </p>
        </div>

        {%- comment -%} Preferred Time — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="party-time" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Preferred Time <span style="color:var(--orange);">*</span>
          </label>
          <select
            id="party-time"
            name="properties[Preferred Time]"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;appearance:none;-webkit-appearance:none;background-image:url('data:image/svg+xml;utf8,<svg fill=\'white\' xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\'><path d=\'M7 10l5 5 5-5z\'/></svg>');background-repeat:no-repeat;background-position:right 12px center;background-size:20px;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
            <option value="" disabled selected>Select a time...</option>
            <option value="9:00 AM">9:00 AM</option>
            <option value="9:30 AM">9:30 AM</option>
            <option value="10:00 AM">10:00 AM</option>
            <option value="10:30 AM">10:30 AM</option>
            <option value="11:00 AM">11:00 AM</option>
            <option value="11:30 AM">11:30 AM</option>
            <option value="12:00 PM">12:00 PM</option>
            <option value="12:30 PM">12:30 PM</option>
            <option value="1:00 PM">1:00 PM</option>
            <option value="1:30 PM">1:30 PM</option>
            <option value="2:00 PM">2:00 PM</option>
            <option value="2:30 PM">2:30 PM</option>
            <option value="3:00 PM">3:00 PM</option>
            <option value="3:30 PM">3:30 PM</option>
            <option value="4:00 PM">4:00 PM</option>
            <option value="4:30 PM">4:30 PM</option>
            <option value="5:00 PM">5:00 PM</option>
            <option value="5:30 PM">5:30 PM</option>
            <option value="6:00 PM">6:00 PM</option>
            <option value="6:30 PM">6:30 PM</option>
            <option value="7:00 PM">7:00 PM</option>
            <option value="7:30 PM">7:30 PM</option>
            <option value="8:00 PM">8:00 PM</option>
            <option value="8:30 PM">8:30 PM</option>
            <option value="9:00 PM">9:00 PM</option>
          </select>
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            What time would you like the gates opened?
          </p>
        </div>

        {%- comment -%} Expected Number of Kids — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="expected-kids" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Expected Number of Kids <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="number"
            id="expected-kids"
            name="properties[Expected Number of Kids]"
            placeholder="e.g. 15"
            min="1"
            max="100"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Contact Phone — Required {%- endcomment -%}
        <div style="margin-bottom:16px;">
          <label for="contact-phone" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Contact Phone <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="tel"
            id="contact-phone"
            name="properties[Contact Phone]"
            placeholder="e.g. 0412 345 678"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
        </div>

        {%- comment -%} Email Address — Required {%- endcomment -%}
        <div style="margin-bottom:24px;">
          <label for="customer-email" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
            Email Address <span style="color:var(--orange);">*</span>
          </label>
          <input
            type="email"
            id="customer-email"
            name="properties[Email]"
            placeholder="e.g. sarah@example.com"
            required
            style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='var(--orange, #ff6600)'"
            onblur="this.style.borderColor='var(--gray-600, #444)'"
          >
          <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
            We'll send booking confirmation and party details to this email.
          </p>
        </div>

        {% if is_premium %}
          {%- comment -%} ========== PIZZA SELECTION (Quantity Based on Package) ========== {%- endcomment -%}
          <div style="border-top:1px solid var(--gray-600,#444);padding-top:24px;margin-top:8px;margin-bottom:24px;">
            <h3 style="font-size:16px;font-weight:800;color:var(--white);margin-bottom:4px;"> CHOOSE YOUR PIZZAS</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-bottom:16px;">{{ pizza_count }} pizzas included. Extra pizzas: $18 each.</p>
            
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              {% assign pizzas = "Margherita,Pepperoni,Meat Lovers,Hawaiian" | split:"," %}
              {% for pizza in pizzas %}
                <div style="display:flex;align-items:center;gap:10px;padding:12px;background:var(--gray-700,#222);border-radius:6px;border:1px solid var(--gray-600,#444);">
                  <label for="pizza-qty-{{ forloop.index }}" style="color:var(--white);flex:1;font-weight:600;">{{ pizza }}</label>
                  <input 
                    type="number" 
                    id="pizza-qty-{{ forloop.index }}" 
                    name="properties[{{ pizza }} Qty]" 
                    value="0" 
                    min="0" 
                    max="20"
                    style="width:60px;padding:8px;font-size:14px;border:1px solid var(--gray-600,#444);border-radius:4px;background:var(--gray-800,#1a1a1a);color:var(--orange,#ff6600);font-weight:700;text-align:center;"
                  >
                </div>
              {% endfor %}
            </div>
          </div>

          {%- comment -%} ========== BURGER SELECTION ========== {%- endcomment -%}
          <div style="margin-bottom:24px;">
            <h3 style="font-size:16px;font-weight:800;color:var(--white);margin-bottom:4px;"> CHOOSE YOUR BURGERS</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-bottom:16px;">Select burger quantities.</p>
            
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              {% assign burgers = "Hamburger,Meat Burger,Cheeseburger" | split:"," %}
              {% for burger in burgers %}
                <div style="display:flex;align-items:center;gap:10px;padding:12px;background:var(--gray-700,#222);border-radius:6px;border:1px solid var(--gray-600,#444);">
                  <label for="burger-qty-{{ forloop.index }}" style="color:var(--white);flex:1;font-weight:600;">{{ burger }}</label>
                  <input 
                    type="number" 
                    id="burger-qty-{{ forloop.index }}" 
                    name="properties[{{ burger }} Qty]" 
                    value="0" 
                    min="0" 
                    max="30"
                    style="width:60px;padding:8px;font-size:14px;border:1px solid var(--gray-600,#444);border-radius:4px;background:var(--gray-800,#1a1a1a);color:var(--orange,#ff6600);font-weight:700;text-align:center;"
                  >
                </div>
              {% endfor %}
            </div>
          </div>

          {%- comment -%} ========== DRINK SELECTION (With 2L & 1.25L Options) ========== {%- endcomment -%}
          <div style="margin-bottom:24px;">
            <h3 style="font-size:16px;font-weight:800;color:var(--white);margin-bottom:4px;"> SELECT SOFT DRINKS</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-bottom:16px;">{{ drink_count }} × 2L bottles included. Choose your mix of 2L or 1.25L sizes.</p>
            
            <div style="display:grid;grid-template-columns:1fr;gap:16px;">
              {% assign drinks = "Coca-Cola,Coke Zero,Sprite,Fanta Orange,Lemonade,Iced Tea,Water" | split:"," %}
              {% for drink in drinks %}
                <div style="padding:12px;background:var(--gray-700,#222);border-radius:6px;border:1px solid var(--gray-600,#444);">
                  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                    <label style="color:var(--white);font-weight:600;flex:1;">{{ drink }}</label>
                    
                    {%- comment -%} 2L Option {%- endcomment -%}
                    <div style="display:flex;align-items:center;gap:6px;">
                      <label for="drink-2L-{{ forloop.index }}" style="color:var(--gray-300);font-size:12px;">2L</label>
                      <input 
                        type="number" 
                        id="drink-2L-{{ forloop.index }}" 
                        name="properties[{{ drink }} 2L]" 
                        value="0" 
                        min="0" 
                        max="10"
                        style="width:50px;padding:6px;font-size:13px;border:1px solid var(--gray-600,#444);border-radius:4px;background:var(--gray-800,#1a1a1a);color:var(--orange,#ff6600);font-weight:700;text-align:center;"
                      >
                    </div>
                    
                    {%- comment -%} 1.25L Option {%- endcomment -%}
                    <div style="display:flex;align-items:center;gap:6px;">
                      <label for="drink-1.25L-{{ forloop.index }}" style="color:var(--gray-300);font-size:12px;">1.25L</label>
                      <input 
                        type="number" 
                        id="drink-1.25L-{{ forloop.index }}" 
                        name="properties[{{ drink }} 1.25L]" 
                        value="0" 
                        min="0" 
                        max="10"
                        style="width:50px;padding:6px;font-size:13px;border:1px solid var(--gray-600,#444);border-radius:4px;background:var(--gray-800,#1a1a1a);color:var(--orange,#ff6600);font-weight:700;text-align:center;"
                      >
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          {%- comment -%} Special Requests / Notes (Premium Only) {%- endcomment -%}
          <div style="margin-bottom:24px;">
            <label for="food-notes" style="display:block;font-weight:700;font-size:14px;color:var(--white);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">
              Special Food Requests (Optional)
            </label>
            <textarea
              id="food-notes"
              name="properties[Food Special Requests]"
              rows="3"
              placeholder="e.g. 'No pepperoni for 3 kids', 'allergies: peanuts', 'extra ice please'"
              style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--gray-600, #444);border-radius:8px;background:var(--gray-800, #1a1a1a);color:var(--white, #fff);outline:none;transition:border-color 0.2s;resize:vertical;font-family:inherit;"
              onfocus="this.style.borderColor='var(--orange, #ff6600)'"
              onblur="this.style.borderColor='var(--gray-600, #444)'"
            ></textarea>
            <p style="font-size:12px;color:var(--gray-400, #999);margin-top:4px;">
              This helps us personalise the food experience for your party.
            </p>
          </div>
        {% endif %}
      </div>

      <button type="submit" class="btn-primary" style="margin-top:8px;">
        Book Now — {{ product.price | money }}
      </button>
    {% endform %}
  {% else %}
    <p style="margin-top:24px;font-size:18px;color:var(--orange);font-weight:700;">Currently Unavailable</p>
  {% endif %}
</div>
